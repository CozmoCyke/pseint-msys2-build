// Approximate expected output for CBOTExporter V3

// ADVERTENCIA: Dimension se refleja sobre todo en la declaracion del arreglo; la materializacion runtime exacta no se fuerza en V3.

extern void object::pruebadimension() {
	int v[5];
	// Dimension(v): se exporta principalmente en la declaracion del arreglo.
	// ADVERTENCIA: CBOT materializa el arreglo al primer acceso o asignacion; V3 no fuerza esa inicializacion.
	v[0] = 10;
	message("" + (v[0]));
}
