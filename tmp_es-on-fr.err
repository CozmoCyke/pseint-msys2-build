LANGTRACE before_set_exepath
LANGTRACE after_set_exepath
LANGTRACE step=parse arg=fr
LANGKW ALGORITMO=Algoritmo
LANGKW FINALGORITMO=FinAlgoritmo
LANGKW DEFINIR=Definir
LANGKW COMO=Como
LANGTRACE before_setlanguage_call lang_code=fr
LANGTRACE SetLanguage requested=fr
