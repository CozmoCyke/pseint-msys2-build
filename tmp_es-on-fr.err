LANGTRACE SetLanguage loaded path=C:\msys64\home\Lenovo\src\ppp\bin/../lang/fr.txt
LANGTRACE after_setlanguage_call
LANGTRACE postset ALGORITMO=Algoritmo
LANGTRACE postset FINALGORITMO=FinAlgoritmo
LANGTRACE postset DEFINIR=Definir
LANGTRACE postset COMO=Como
LANGTRACE set_current_lang before=es after=fr source=main
KWFIX overlay path=keywords/fr.ini
LANGTRACE engine current_lang=fr
LANGTRACE postfix current_lang=fr
